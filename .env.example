# Firebase Configuration
# Copy this file to .env and fill in your actual values
# .env should NEVER be committed to git

# Firebase Project ID (public, safe to share)
FIREBASE_PROJECT_ID=admissions-intelligence-2fc32

# Firebase Service Account Key (KEEP SECRET)
# Paste the entire JSON content from your Firebase service account key file
# OR set the path to the JSON file
FIREBASE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"admissions-intelligence-2fc32",...}

# Alternative: Path to service account JSON file (if using file-based auth)
# FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/path/to/firebase-key.json

# Firestore Configuration
FIRESTORE_COLLECTION=extracted_records

# Cloud Run Backend (after deployment)
# VITE_API_BASE=https://YOUR-CLOUD-RUN-URL.run.app

# Environment
ENVIRONMENT=development
