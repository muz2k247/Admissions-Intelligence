# Admin CMS config. Firebase web config values are NOT secrets (security is
# enforced by Firestore rules, not key secrecy) -- but per CLAUDE.md's
# never-commit-.env rule, copy this to `.env` (git-ignored) and fill in real
# values; never commit the filled-in file.
#
# Get these from Firebase Console -> Project settings -> Your apps -> Web app.
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=admissions-intelligence-2fc32.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=admissions-intelligence-2fc32
VITE_FIREBASE_APP_ID=your-web-app-id

# URL the admin app reads already-published records from (the public site's
# static data). Defaults to the live public site if unset.
VITE_PUBLIC_DATA_URL=https://admissions-intelligence-2fc32.web.app/data/records.json

# URL the admin app reads the Phase Q needs-review queue from (same public
# site, the pipeline's other static output). Defaults to the live public
# site if unset.
VITE_PUBLIC_NEEDS_REVIEW_URL=https://admissions-intelligence-2fc32.web.app/data/needs_review.json

# URL the admin app reads the Phase R institutions list from (same public
# site's static institutions.json). Defaults to the live public site if unset.
VITE_PUBLIC_INSTITUTIONS_URL=https://admissions-intelligence-2fc32.web.app/data/institutions.json
