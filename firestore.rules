rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read-only access to extracted admissions records
    // Write access only via admin SDK (backend + pipeline job)
    match /extracted_records/{document=**} {
      // Allow anyone to read
      allow read: if true;

      // Only allow write via authenticated admin SDK
      // (This is enforced by using Firebase service account in backend/pipeline)
      allow write: if false;
      allow delete: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
